{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rowshape.com/schema/fixture/v1",
  "title": "Rowshape Fixture",
  "description": "A rowshape.yaml fixture, format version \"1\" (RFC-0001). A fixture contains no rows from a database — only statistics computed from them, each carrying the confidence it is known at. Unknown fields are ignored by readers (RFC §12); x_-prefixed keys are reserved for vendor extensions.",
  "type": "object",
  "required": [
    "rowshape_fixture",
    "meta",
    "tables"
  ],
  "additionalProperties": true,
  "properties": {
    "rowshape_fixture": {
      "description": "Format version. A reader understands a whole major: it accepts \"1\" and any minor within it (\"1.4\") and MUST refuse a different major (RFC §12).",
      "type": "string",
      "pattern": "^1(\\.[0-9]+)*$"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "tables": {
      "type": "object",
      "description": "Qualified table name (schema.table) -> table profile.",
      "additionalProperties": {
        "$ref": "#/$defs/table"
      }
    }
  },
  "$defs": {
    "confidence": {
      "description": "The confidence a fact is known at, strictly ordered exact > measured > estimated > declared (RFC §7.1).",
      "type": "string",
      "enum": [
        "exact",
        "measured",
        "estimated",
        "declared"
      ]
    },
    "meta": {
      "type": "object",
      "required": [
        "engine"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "generator": {
          "type": "string"
        },
        "engine": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": true,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "description": "Engine major version — mandatory, because cost models are engine-version-conditional (RFC §9.1).",
              "type": "string",
              "minLength": 1
            }
          }
        },
        "privacy": {
          "enum": [
            "strict",
            "standard",
            "permissive"
          ]
        },
        "source": {
          "type": "string"
        },
        "profile": {
          "type": "object"
        },
        "digest": {
          "type": "string"
        }
      }
    },
    "intFact": {
      "description": "An integer fact, as a {value, confidence, via} object or a bare scalar (shorthand for confidence:estimated, RFC §6.1).",
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "object",
          "required": [
            "value"
          ],
          "additionalProperties": true,
          "properties": {
            "value": {
              "type": "integer"
            },
            "confidence": {
              "$ref": "#/$defs/confidence"
            },
            "via": {
              "type": "string"
            },
            "error": {
              "type": "number"
            }
          }
        }
      ]
    },
    "floatFact": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "object",
          "required": [
            "value"
          ],
          "additionalProperties": true,
          "properties": {
            "value": {
              "type": "number"
            },
            "confidence": {
              "$ref": "#/$defs/confidence"
            },
            "via": {
              "type": "string"
            },
            "error": {
              "type": "number"
            }
          }
        }
      ]
    },
    "uniqueFact": {
      "description": "Uniqueness. It MUST be exact or absent — a sample can never establish it (RFC §7.2). As an object, confidence is constrained to exact.",
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "required": [
            "value"
          ],
          "additionalProperties": true,
          "properties": {
            "value": {
              "type": "boolean"
            },
            "confidence": {
              "const": "exact"
            },
            "via": {
              "type": "string"
            }
          }
        }
      ]
    },
    "table": {
      "type": "object",
      "required": [
        "rows"
      ],
      "additionalProperties": true,
      "properties": {
        "rows": {
          "$ref": "#/$defs/intFact"
        },
        "bytes": {
          "type": "integer"
        },
        "columns": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/column"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "partitions": {
          "type": "object"
        }
      }
    },
    "column": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "nullable": {
          "type": "boolean"
        },
        "null_fraction": {
          "$ref": "#/$defs/floatFact"
        },
        "distinct": {
          "$ref": "#/$defs/intFact"
        },
        "unique": {
          "$ref": "#/$defs/uniqueFact"
        },
        "generated": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "length": {
          "type": "object"
        },
        "range": {
          "type": "object"
        },
        "histogram": {
          "type": "object"
        },
        "shape": {},
        "values": {
          "type": "array"
        },
        "frequencies": {
          "type": "array"
        },
        "redact": {}
      },
      "allOf": [
        {
          "title": "RFC §6.1 — no range on text/bytea",
          "description": "A text or bytea column MUST NOT carry a range: its min and max would be REAL PRODUCTION VALUES, which is exactly what a fixture must never contain (INV-NO-ROWS). Numeric and temporal ranges are bounds; text ranges are data. Enforced here as well as in the Go conformance suite so a third-party emitter validating against the published schema alone cannot emit an invalid fixture.",
          "if": {
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "pattern": "^\\s*([cC][hH][aA][rR][aA][cC][tT][eE][rR]\\s+[vV][aA][rR][yY][iI][nN][gG]|[cC][hH][aA][rR][aA][cC][tT][eE][rR]|[vV][aA][rR][cC][hH][aA][rR]|[cC][iI][tT][eE][xX][tT]|[bB][yY][tT][eE][aA]|[jJ][sS][oO][nN][bB]|[tT][eE][xX][tT]|[cC][hH][aA][rR]|[jJ][sS][oO][nN])\\s*(\\(\\s*\\d+\\s*\\))?\\s*(\\[\\s*\\])*\\s*$"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "range"
              ]
            },
            "$comment": "range is forbidden on this type"
          }
        }
      ]
    }
  }
}
